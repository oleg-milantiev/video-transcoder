APP_ENV=dev
APP_SECRET=
APP_SHARE_DIR=var/share

DATABASE_URL="postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}?serverVersion=16&charset=utf8"
MESSENGER_TRANSPORT_DSN=redis://${REDIS_HOST}:${REDIS_PORT}/messages
MAILER_DSN=null://null
LOCK_DSN=redis://${REDIS_HOST}:${REDIS_PORT}

MERCURE_PUBLIC_URL=http://localhost:8080/.well-known/mercure
MERCURE_INTERNAL_URL=http://mercure/.well-known/mercure
MERCURE_SUBSCRIBER_JWT_KEY=!ChangeThisMercureSubscriberKey!
MERCURE_PUBLISHER_JWT_KEY=!ChangeThisMercurePublisherKey!
MERCURE_TOPIC_PREFIX=http://yc.local/user
MERCURE_TOKEN_TTL_SECONDS=3600

