{% extends 'base.html.twig' %}

{% block title %}Video Details{% endblock %}

{% block body %}
    <div class="container py-5">
        <h1 class="mb-4">Video Details</h1>
        <div class="card">
            <div class="card-body">
                {% if dto.poster %}
                    <img src="/uploads/{{ dto.poster }}" class="img-fluid mb-3 rounded" alt="{{ dto.title }}">
                {% endif %}
                <dl class="row">
                    <dt class="col-sm-3">Title</dt>
                    <dd class="col-sm-9">{{ dto.title }}</dd>
                    <dt class="col-sm-3">Extension</dt>
                    <dd class="col-sm-9">{{ dto.extension }}</dd>
                    <dt class="col-sm-3">Status</dt>
                    <dd class="col-sm-9">{{ dto.status }}</dd>
                    <dt class="col-sm-3">Created At</dt>
                    <dd class="col-sm-9">{{ dto.createdAt }}</dd>
                    <dt class="col-sm-3">Updated At</dt>
                    <dd class="col-sm-9">{{ dto.updatedAt ?: '-' }}</dd>
                    <dt class="col-sm-3">User ID</dt>
                    <dd class="col-sm-9">{{ dto.userId }}</dd>
                </dl>

                <h5 class="mt-4">Presets</h5>
                <table class="table table-bordered">
                    <thead>
                        <tr>
                            <th>Preset</th>
                            <th>Status</th>
                            <th>Progress</th>
                            <th>Created</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for preset in dto.presetsWithTasks %}
                            <tr>
                                <td>{{ preset.name }}</td>
                                {% if preset.task %}
                                    <td>{{ preset.task.status }}</td>
                                    <td>{{ preset.task.progress }}%</td>
                                    <td>{{ preset.task.createdAt }}</td>
                                {% else %}
                                    <td colspan="3">
                                        <div class="d-flex justify-content-between align-items-center">
                                            <em>No task</em>
                                            {# Button enabled by default. JS will POST to the transcode route and disable it on click. #}
                                            <button
                                                type="button"
                                                class="btn btn-primary btn-sm js-transcode-btn ms-3"
                                                data-url="{{ path('video_transcode', {'id': dto.id, 'presetId': preset.id}) }}"
                                                style="margin-left:auto;"
                                            >
                                                Transcode
                                            </button>
                                        </div>
                                    </td>
                                {% endif %}
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>

                <h5 class="mt-4">Meta</h5>
                <ul>
                    {% for key, value in dto.meta %}
                        <li><strong>{{ key }}:</strong> {{ value }}</li>
                    {% else %}
                        <li><em>No meta data</em></li>
                    {% endfor %}
                </ul>
            </div>
        </div>
        <a href="{{ path('video') }}" class="btn btn-secondary mt-3">Back to list</a>
    </div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        (function () {
            function onClick(e) {
                var btn = e.currentTarget;
                var url = btn.getAttribute('data-url');
                if (!url) return;

                // disable immediately to prevent double clicks
                btn.disabled = true;
                var originalText = btn.textContent;
                btn.textContent = 'Processing...';

                fetch(url, {
                    method: 'POST',
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest',
                        'Content-Type': 'application/json'
                    },
                    credentials: 'same-origin'
                }).then(function (resp) {
                    if (resp.ok) {
                        // keep disabled and show queued state
                        btn.textContent = 'Queued';
                    } else {
                        // re-enable on error
                        btn.disabled = false;
                        btn.textContent = originalText;
                        resp.text().then(function (t) { console.error('Transcode failed:', t); });
                        alert('Failed to start transcode.');
                    }
                }).catch(function (err) {
                    console.error(err);
                    btn.disabled = false;
                    btn.textContent = originalText;
                    alert('Network error while starting transcode.');
                });
            }

            document.addEventListener('DOMContentLoaded', function () {
                var buttons = document.querySelectorAll('.js-transcode-btn');
                buttons.forEach(function (b) { b.addEventListener('click', onClick); });
            });
        })();
    </script>
{% endblock %}

