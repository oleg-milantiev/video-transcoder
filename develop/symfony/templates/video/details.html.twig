{% extends 'base.html.twig' %}

{% block title %}Video Details{% endblock %}

{% block body %}
    <div class="container py-5">
        <h1 class="mb-4">Video Details</h1>
        <div class="card">
            <div class="card-body">
                {% if dto.poster %}
                    <img src="/uploads/{{ dto.poster }}" class="img-fluid mb-3 rounded" alt="{{ dto.title }}">
                {% endif %}
                <dl class="row">
                    <dt class="col-sm-3">Title</dt>
                    <dd class="col-sm-9">{{ dto.title }}</dd>
                    <dt class="col-sm-3">Extension</dt>
                    <dd class="col-sm-9">{{ dto.extension }}</dd>
                    <dt class="col-sm-3">Status</dt>
                    <dd class="col-sm-9">{{ dto.status }}</dd>
                    <dt class="col-sm-3">Created At</dt>
                    <dd class="col-sm-9">{{ dto.createdAt }}</dd>
                    <dt class="col-sm-3">Updated At</dt>
                    <dd class="col-sm-9">{{ dto.updatedAt ?: '-' }}</dd>
                    <dt class="col-sm-3">User ID</dt>
                    <dd class="col-sm-9">{{ dto.userId }}</dd>
                </dl>

                <h5 class="mt-4">Presets</h5>
                <table class="table table-bordered">
                    <thead>
                        <tr>
                            <th>Preset</th>
                            <th>Status</th>
                            <th>Progress</th>
                            <th>Created</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for preset in dto.presetsWithTasks %}
                            <tr>
                                <td>{{ preset.name }}</td>
                                {% if preset.task %}
                                    <td>{{ preset.task.status|title }}</td>
                                    <td>{{ preset.task.progress }}%</td>
                                    <td>{{ preset.task.createdAt }}</td>
                                    <td>
                                        {% if preset.task.status == 'COMPLETED' and preset.task.id %}
                                            <a href="{{ path('task_download', {'id': preset.task.id}) }}" class="btn btn-outline-primary btn-sm" download>
                                                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true" class="me-1">
                                                    <path d="M8 1a.5.5 0 0 1 .5.5v7.793l2.146-2.147a.5.5 0 1 1 .708.708l-3 3a.5.5 0 0 1-.708 0l-3-3a.5.5 0 1 1 .708-.708L7.5 9.293V1.5A.5.5 0 0 1 8 1z"/>
                                                    <path d="M2.5 12a.5.5 0 0 1 .5.5v1h10v-1a.5.5 0 0 1 1 0V14a.5.5 0 0 1-.5.5h-11A.5.5 0 0 1 2 14v-1.5a.5.5 0 0 1 .5-.5z"/>
                                                </svg>
                                                Download
                                            </a>
                                        {% else %}
                                            <span class="text-muted">-</span>
                                        {% endif %}
                                    </td>
                                {% else %}
                                    <td><em>No task</em></td>
                                    <td><span class="text-muted">-</span></td>
                                    <td><span class="text-muted">-</span></td>
                                    <td>
                                        <button
                                            type="button"
                                            class="btn btn-outline-primary btn-sm js-transcode-btn"
                                            data-url="{{ path('video_transcode', {'id': dto.id, 'presetId': preset.id}) }}"
                                        >
                                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true" class="me-1">
                                                <path d="M8 3a5 5 0 0 1 4.546 2.916.5.5 0 1 0 .908-.418A6 6 0 1 0 13.5 8h-1a5 5 0 1 1-1.46-3.54L9.5 6H13V2.5l-1.607 1.607A5.98 5.98 0 0 0 8 3z"/>
                                            </svg>
                                            Transcode
                                        </button>
                                    </td>
                                {% endif %}
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>

                <h5 class="mt-4">Meta</h5>
                <ul>
                    {% for key, value in dto.meta %}
                        <li><strong>{{ key }}:</strong> {{ value }}</li>
                    {% else %}
                        <li><em>No meta data</em></li>
                    {% endfor %}
                </ul>
            </div>
        </div>
    </div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        (function () {
            function onClick(e) {
                var btn = e.currentTarget;
                var url = btn.getAttribute('data-url');
                if (!url) return;

                // disable immediately to prevent double clicks
                btn.disabled = true;
                var originalText = btn.textContent;
                btn.textContent = 'Processing...';

                fetch(url, {
                    method: 'POST',
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest',
                        'Content-Type': 'application/json'
                    },
                    credentials: 'same-origin'
                }).then(function (resp) {
                    if (resp.ok) {
                        // keep disabled and show queued state
                        btn.textContent = 'Queued';
                    } else {
                        // re-enable on error
                        btn.disabled = false;
                        btn.textContent = originalText;
                        resp.text().then(function (t) { console.error('Transcode failed:', t); });
                        alert('Failed to start transcode.');
                    }
                }).catch(function (err) {
                    console.error(err);
                    btn.disabled = false;
                    btn.textContent = originalText;
                    alert('Network error while starting transcode.');
                });
            }

            document.addEventListener('DOMContentLoaded', function () {
                var buttons = document.querySelectorAll('.js-transcode-btn');
                buttons.forEach(function (b) { b.addEventListener('click', onClick); });
            });
        })();
    </script>
{% endblock %}
