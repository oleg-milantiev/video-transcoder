{% extends 'base.html.twig' %}

{% block title %}Video Transcoder{% endblock %}

{% block stylesheets %}
    {# Prevent Turbo Drive from caching this page.
       Without this, a cached snapshot carries data-vue-mounted="1" and
       mountHomeSpa() would bail out early on restore, leaving a dead DOM.
       With no-cache, Turbo always does a fresh fetch, so the page boots cleanly. #}
    <meta name="turbo-cache-control" content="no-cache">
    <link href="https://releases.transloadit.com/uppy/v3.21.0/uppy.min.css" rel="stylesheet">

    {{ parent() }}
{% endblock %}

{% block javascripts %}
    <script src="https://releases.transloadit.com/uppy/v3.21.0/uppy.min.js"></script>

    {{ parent() }}
{% endblock %}

{% block body %}
    {% set dummyUuid = '11111111-1111-4111-8111-111111111111' %}
    {% set dummyPresetId = '22222222-2222-4222-8222-222222222222' %}
    {% set dummyTaskId = '33333333-3333-4333-8333-333333333333' %}
    <div class="container py-5">
        {% if app.user %}
            <div id="home-spa"></div>
            {# Use var (not const) so Turbo can re-execute this script on navigation
               without hitting "Identifier 'config' has already been declared". #}
            <script>var config = {{ config|json_encode|raw }};</script>
        {% else %}
            <p>Please <a href="{{ path('app_login') }}" class="btn btn-primary">Sign in</a>.</p>
        {% endif %}
    </div>
{% endblock %}
