{% extends 'base.html.twig' %}

{% block title %}Video Transcoder{% endblock %}

{% block stylesheets %}
    <link href="https://releases.transloadit.com/uppy/v3.21.0/uppy.min.css" rel="stylesheet">
    <link href="https://cdn.datatables.net/1.13.8/css/dataTables.bootstrap5.min.css" rel="stylesheet">

    {{ parent() }}
{% endblock %}

{% block javascripts %}
    <script src="https://releases.transloadit.com/uppy/v3.21.0/uppy.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.8/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.8/js/dataTables.bootstrap5.min.js"></script>

    {{ parent() }}
{% endblock %}

{% block body %}
    <div class="container py-5">

        <h1 class="mb-4">Video Transcoder</h1>

        {% if app.user %}
            <p>You are logged in as <strong>{{ app.user.userIdentifier }}</strong>.</p>

            <ul class="nav nav-tabs" id="mainTabs" role="tablist">
                <li class="nav-item">
                    <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#upload">
                        Upload
                    </button>
                </li>
                <li class="nav-item">
                    <button class="nav-link" data-bs-toggle="tab" data-bs-target="#videos">
                        Videos
                    </button>
                </li>
                <li class="nav-item">
                    <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tasks">
                        Tasks
                    </button>
                </li>
            </ul>

            <div class="tab-content border border-top-0 p-4 bg-light">

                {# ================= UPLOAD ================= #}
                <div class="tab-pane fade show active" id="upload">

                    <div id="drag-drop-area"></div>

                    <script>
                        function uuidv4() {
                            return 'xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx'.replace(/[xy]/g, function(c) {
                                const r = crypto.getRandomValues(new Uint8Array(1))[0] & 15;
                                const v = c === 'x' ? r : (r & 0x3 | 0x8);
                                return v.toString(16);
                            });
                        }

                        const allowedExtensions = ['mp4','mkv','avi','mov'];

                        const uppy = new Uppy.Uppy({
                            autoProceed: true,
                            restrictions: {
                                allowedFileTypes: allowedExtensions.map(ext => '.'+ext)
                            }
                        })
                            .use(Uppy.Dashboard,{
                                inline:true,
                                target:'#drag-drop-area',
                                proudlyDisplayPoweredByUppy:false
                            })
                            .use(Uppy.Tus,{
                                endpoint:'{{ path('api_tus') }}',
                                chunkSize:5*1024*1024
                            });

                        uppy.on('file-added',(file)=>{
                            const uuid = uuidv4();
                            const ext = file.name.split('.').pop().toLowerCase();

                            uppy.setFileMeta(file.id,{
                                name: uuid+'.'+ext,
                                originalName:file.name
                            });
                        });
                    </script>
                </div>

                {# ================= VIDEOS ================= #}
                <div class="tab-pane fade" id="videos">

                    <table id="videosTable" class="table table-striped w-100">
                        <thead>
                        <tr>
                            <th>Poster</th>
                            <th>Name</th>
                            <th>Status</th>
                            <th>Created</th>
                        </tr>
                        </thead>
                    </table>
                </div>

                {# ================= TASKS ================= #}
                <div class="tab-pane fade" id="tasks">

                    <table id="tasksTable" class="table table-striped w-100">
                        <thead>
                        <tr>
                            <th>Video</th>
                            <th>Preset</th>
                            <th>Status</th>
                            <th>Progress</th>
                            <th>Created</th>
                            <th>Actions</th>
                        </tr>
                        </thead>
                    </table>

                </div>

            </div>

        {% else %}
            <p>Please <a href="{{ path('app_login') }}" class="btn btn-primary">Sign in</a>.</p>
        {% endif %}
    </div>




    <script>
        document.addEventListener('DOMContentLoaded', function () {

            /* ---------- VIDEOS TABLE ---------- */

            const videosTable = new DataTable('#videosTable', {
                ajax: {
                    url: '{{ path('api_video_list') }}',
                    dataSrc: ''
                },
                pageLength: 10,
                columns: [
                    {
                        data: 'poster',
                        orderable: false,
                        render: function(data, type, row) {
                            if (data) {
                                return `<img src="/uploads/${data}" alt="poster" style="width:150px;max-width:100%;height:auto;object-fit:cover;border-radius:6px;">`;
                            } else {
                                return `<div style="width:150px;height:84px;background:#eee;display:flex;align-items:center;justify-content:center;color:#aaa;font-size:12px;border-radius:6px;">No poster</div>`;
                            }
                        }
                    },
                    {data:'title'},
                    {data:'status'},
                    {data:'createdAt'}
                ],
                order: [[3, 'desc']]
            });

            // CLICK ROW -> open details page in new tab
            document.querySelector('#videosTable tbody')
                .addEventListener('click', function(e){
                    const row = videosTable.row(e.target.closest('tr')).data();
                    if (!row) return;
                    if (row.uuid) {
                        const detailsUrlTemplate = '{{ path('video_details', {'uuid': '__UUID__'}) }}';
                        window.open(detailsUrlTemplate.replace('__UUID__', row.uuid), '_blank');
                    }
                });


            /* ---------- TASKS TABLE ---------- */

            new DataTable('#tasksTable', {
                ajax: {
                    url: '{{ path('api_task_list') }}',
                    dataSrc: ''
                },
                pageLength: 10,
                columns: [
                    {data:'videoTitle'},
                    {data:'presetTitle'},
                    {data:'status'},
                    {data:'progress'},
                    {data:'createdAt'},
                    {
                        data: null,
                        orderable: false,
                        render: function(data, type, row) {
                            if (row.status === 'COMPLETED' && row.id) {
                                const downloadUrlTemplate = '{{ path('task_download', {'id': '__TASK_ID__'}) }}';
                                return `
                                    <a href="${downloadUrlTemplate.replace('__TASK_ID__', row.id)}" class="btn btn-outline-primary btn-sm" download>
                                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true" class="me-1">
                                            <path d="M8 1a.5.5 0 0 1 .5.5v7.793l2.146-2.147a.5.5 0 1 1 .708.708l-3 3a.5.5 0 0 1-.708 0l-3-3a.5.5 0 1 1 .708-.708L7.5 9.293V1.5A.5.5 0 0 1 8 1z"/>
                                            <path d="M2.5 12a.5.5 0 0 1 .5.5v1h10v-1a.5.5 0 0 1 1 0V14a.5.5 0 0 1-.5.5h-11A.5.5 0 0 1 2 14v-1.5a.5.5 0 0 1 .5-.5z"/>
                                        </svg>
                                        Download
                                    </a>
                                `;
                            }

                            return '<span class="text-muted">-</span>';
                        }
                    }
                ],
                order: [[4, 'desc']]
            });

        });
    </script>

{% endblock %}
